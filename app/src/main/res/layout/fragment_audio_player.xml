<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorPrimary"
    tools:context=".root.ui.RootActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context="com.practicum.playlistmaker.player.ui.AudioPlayerFragment">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/leftBorder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="@dimen/padding_medium" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/rightBorder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="@dimen/padding_medium" />

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/menu_button"
                style="@style/ToolbarStyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:navigationIcon="@drawable/ic_back_arrow_24"
                app:navigationIconTint="?attr/colorControlNormal"
                app:title=" " />

            <ImageView
                android:id="@+id/imageAlbum"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginHorizontal="@dimen/padding_small_8"
                android:layout_marginTop="26dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_placeholder_312"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintEnd_toStartOf="@id/rightBorder"
                app:layout_constraintHeight_max="512dp"
                app:layout_constraintStart_toEndOf="@id/leftBorder"
                app:layout_constraintTop_toBottomOf="@id/menu_button"
                app:layout_constraintWidth_max="512dp" />

            <TextView
                android:id="@+id/trackName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_small_8"
                android:layout_marginTop="26dp"
                android:fontFamily="@font/ys_display_medium"
                android:textColor="?attr/colorControlNormal"
                android:textFontWeight="400"
                android:textSize="22sp"
                app:layout_constraintEnd_toStartOf="@id/rightBorder"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTop_toBottomOf="@id/imageAlbum"
                tools:text="@string/track_name" />

            <TextView
                android:id="@+id/trackArtist"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_small_8"
                android:layout_marginTop="@dimen/padding_12"
                android:fontFamily="@font/ys_display_medium"
                android:textColor="?attr/colorControlNormal"
                android:textFontWeight="400"
                android:textSize="@dimen/text_size_14"
                app:layout_constraintEnd_toStartOf="@id/rightBorder"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTop_toBottomOf="@id/trackName"
                tools:text="@string/track_artist" />

            <ImageView
                android:id="@+id/add_to_pl"
                style="@style/ImageViewAudioPlayer"
                android:layout_marginStart="@dimen/padding_small_8"
                android:background="@drawable/round_button"
                android:padding="14dp"
                android:src="@drawable/ic_add_to_pl_23"
                app:layout_constraintEnd_toStartOf="@id/play"
                app:layout_constraintHorizontal_chainStyle="spread_inside"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTop_toBottomOf="@id/trackArtist" />

            <ImageView
                android:id="@+id/play"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="38.33dp"
                android:src="@drawable/ic_play_83"
                app:layout_constraintEnd_toStartOf="@id/like"
                app:layout_constraintStart_toEndOf="@id/add_to_pl"
                app:layout_constraintTop_toBottomOf="@id/trackArtist"
                app:tint="?attr/colorControlNormal" />

            <ImageView
                android:id="@+id/pause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="38.33dp"
                android:src="@drawable/ic_pause_84"
                android:visibility="gone"
                app:layout_constraintEnd_toStartOf="@id/like"
                app:layout_constraintStart_toEndOf="@id/add_to_pl"
                app:layout_constraintTop_toBottomOf="@id/trackArtist"
                app:tint="?attr/colorControlNormal" />

            <ImageView
                android:id="@+id/like"
                style="@style/ImageViewAudioPlayer"
                android:layout_marginEnd="@dimen/padding_small_8"
                android:paddingHorizontal="13dp"
                android:paddingVertical="15dp"
                android:src="@drawable/ic_like_25_23"
                app:layout_constraintEnd_toStartOf="@id/rightBorder"
                app:layout_constraintStart_toEndOf="@+id/play"
                app:layout_constraintTop_toBottomOf="@id/trackArtist" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/playPauseBarrier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="play,pause" />

            <TextView
                android:id="@+id/trackTimeCurrent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_small_8"
                android:layout_marginTop="@dimen/padding_12"
                android:layout_marginBottom="12.33dp"
                android:fontFamily="@font/ys_display_medium"
                android:gravity="center"
                android:text="00:00"
                android:textColor="?attr/colorControlNormal"
                android:textFontWeight="500"
                android:textSize="@dimen/text_size_14"
                app:layout_constraintEnd_toEndOf="@id/like"
                app:layout_constraintStart_toStartOf="@id/add_to_pl"
                app:layout_constraintTop_toBottomOf="@id/playPauseBarrier" />

            <TextView
                android:id="@+id/time"
                style="@style/TextViewAudioPlayer"
                android:layout_marginTop="39dp"
                android:text="@string/time_name"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTag="time"
                app:layout_constraintTop_toBottomOf="@id/trackTimeCurrent" />

            <TextView
                android:id="@+id/album"
                style="@style/TextViewAudioPlayer"
                android:text="@string/album"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTag="album"
                app:layout_constraintTop_toBottomOf="@id/time" />

            <TextView
                android:id="@+id/year"
                style="@style/TextViewAudioPlayer"
                android:text="@string/year"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTag="year"
                app:layout_constraintTop_toBottomOf="@id/album" />

            <TextView
                android:id="@+id/genre"
                style="@style/TextViewAudioPlayer"
                android:text="@string/genre"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTag="genre"
                app:layout_constraintTop_toBottomOf="@id/year" />

            <TextView
                android:id="@+id/country"
                style="@style/TextViewAudioPlayer"
                android:text="@string/country"
                app:layout_constraintStart_toStartOf="@id/leftBorder"
                app:layout_constraintTop_toBottomOf="@id/genre" />

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="end"
                app:constraint_referenced_tags="time,country,genre,year,album" />

            <TextView
                android:id="@+id/trackTime"
                style="@style/TextViewAudioPlayerTrack"
                android:layout_marginTop="39dp"
                android:text="@string/time_name"
                app:layout_constraintEnd_toEndOf="@id/rightBorder"
                app:layout_constraintTop_toBottomOf="@id/trackTimeCurrent"
                tools:text="@string/time_track" />

            <TextView
                android:id="@+id/trackAlbum"
                style="@style/TextViewAudioPlayerTrack"
                android:text="@string/album"
                app:layout_constraintEnd_toEndOf="@id/rightBorder"
                app:layout_constraintTop_toBottomOf="@id/time" />

            <TextView
                android:id="@+id/trackYear"
                style="@style/TextViewAudioPlayerTrack"
                android:text="@string/year_track"
                app:layout_constraintEnd_toEndOf="@id/rightBorder"
                app:layout_constraintTop_toBottomOf="@id/album" />

            <TextView
                android:id="@+id/trackGenre"
                style="@style/TextViewAudioPlayerTrack"
                android:text="@string/genre_track"
                app:layout_constraintEnd_toEndOf="@id/rightBorder"
                app:layout_constraintTop_toBottomOf="@id/year" />

            <TextView
                android:id="@+id/trackCountry"
                style="@style/TextViewAudioPlayerTrack"
                android:text="@string/country_track"
                app:layout_constraintEnd_toEndOf="@id/rightBorder"
                app:layout_constraintTop_toBottomOf="@id/genre" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>


    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/playlists_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_sheet_bg"
        android:orientation="vertical"
        app:behavior_hideable="true"
        app:behavior_peekHeight="240dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounder" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="30dp"
            android:text="@string/add_to_playlist"
            android:fontFamily="@font/ys_display_medium"
            android:textColor="?attr/colorControlNormal"
            android:textFontWeight="500"
            android:textSize="19sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/new_playlist"
            style="@style/NewPlaylistButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingHorizontal="@dimen/padding_small"
            android:paddingVertical="@dimen/padding_10"
            android:layout_marginTop="28dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/playlist_small_view" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>